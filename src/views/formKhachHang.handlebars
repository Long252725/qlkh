<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
        <div class="bg-white shadow-2xl shadow-blue-100 rounded-3xl overflow-hidden border border-slate-100">
            
            <div class="bg-gradient-to-r from-blue-600 to-indigo-700 p-8 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-4 backdrop-blur-md">
                    <i class="fa-solid fa-user-plus text-white text-2xl"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-white tracking-tight">Đăng Ký Khách Hàng</h2>
                <p class="text-blue-100 mt-2 text-sm">Vui lòng điền đầy đủ thông tin bên dưới để khởi tạo tài khoản mới</p>
            </div>

            <div class="p-8 sm:p-10 space-y-8">
                
                <div class="space-y-6">
                    <div class="flex items-center gap-2 border-b border-slate-100 pb-2">
                        <i class="fa-solid fa-id-card text-blue-600"></i>
                        <h3 class="font-bold text-slate-800 uppercase text-xs tracking-wider">Thông tin định danh</h3>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="group">
                            <label for="ho" class="block text-sm font-bold text-slate-700 mb-2 group-focus-within:text-blue-600 transition-colors">Họ</label>
                            <input type="text" id="ho" name="ho" 
                                class="w-full border border-slate-200 p-3 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all bg-slate-50/50 focus:bg-white placeholder:text-slate-400" 
                                placeholder="Ví dụ: Nguyễn">
                        </div>
                        <div class="group">
                            <label for="ten" class="block text-sm font-bold text-slate-700 mb-2 group-focus-within:text-blue-600 transition-colors">Tên</label>
                            <input type="text" id="ten" name="ten" 
                                class="w-full border border-slate-200 p-3 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all bg-slate-50/50 focus:bg-white placeholder:text-slate-400" 
                                placeholder="Ví dụ: Văn A">
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="flex items-center gap-2 border-b border-slate-100 pb-2">
                        <i class="fa-solid fa-envelope-open-text text-blue-600"></i>
                        <h3 class="font-bold text-slate-800 uppercase text-xs tracking-wider">Thông tin liên lạc</h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="group">
                            <label for="email" class="block text-sm font-bold text-slate-700 mb-2 group-focus-within:text-blue-600 transition-colors">Email</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                    <i class="fa-solid fa-at"></i>
                                </span>
                                <input type="email" id="email" name="email" 
                                    class="w-full border border-slate-200 pl-10 p-3 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all bg-slate-50/50 focus:bg-white" 
                                >
                            </div>
                        </div>
                        <div class="group">
                            <label for="sdt" class="block text-sm font-bold text-slate-700 mb-2 group-focus-within:text-blue-600 transition-colors">Số điện thoại</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                                    <i class="fa-solid fa-phone"></i>
                                </span>
                                <input type="text" id="sdt" name="sdt" 
                                    class="w-full border border-slate-200 pl-10 p-3 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all bg-slate-50/50 focus:bg-white" 
                                    >
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="group">
                        <label for="dateOfBirth" class="block text-sm font-bold text-slate-700 mb-2">Ngày sinh</label>
                        <input type="date" id="dateOfBirth" name="dateOfBirth" 
                            class="w-full border border-slate-200 p-3 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all bg-slate-50/50">
                    </div>
                    <div class="group">
                        <label for="gender" class="block text-sm font-bold text-slate-700 mb-2">Giới tính</label>
                        <select id="gender" name="gender" 
                            class="w-full border border-slate-200 p-3 rounded-xl bg-slate-50/50 focus:bg-white focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all appearance-none cursor-pointer">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="block text-sm font-bold text-slate-700">Quê quán (Địa chỉ thường trú)</label>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" id="queQuan">
                        <select id="province" class="border border-slate-200 p-3 rounded-xl bg-slate-50/50 focus:ring-4 focus:ring-blue-100 outline-none transition-all cursor-pointer"><option value="1">Tỉnh/Thành phố</option></select>
                        <select id="district" class="border border-slate-200 p-3 rounded-xl bg-slate-50/50 focus:ring-4 focus:ring-blue-100 outline-none transition-all cursor-pointer"><option value="2">Quận/Huyện</option></select>
                        <select id="ward" class="border border-slate-200 p-3 rounded-xl bg-slate-50/50 focus:ring-4 focus:ring-blue-100 outline-none transition-all cursor-pointer"><option value="3">Phường/Xã</option></select>
                    </div>
                </div>

                <div class="pt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <button type="submit" id="btnSubmit" 
                        class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-xl shadow-blue-200 transition-all hover:-translate-y-1 active:scale-95">
                        <i class="fa-solid fa-circle-check"></i>
                        Xác Nhận Đăng Ký
                    </button>
                    <button type="button" id="btnList" 
                        class="flex items-center justify-center gap-2 bg-white border-2 border-slate-200 hover:border-blue-600 hover:text-blue-600 text-slate-600 font-bold py-4 rounded-2xl transition-all hover:-translate-y-1 active:scale-95">
                        <i class="fa-solid fa-list-ul"></i>
                        Danh Sách KH
                    </button>
                </div>

                <div id="box-show" class="mt-4 flex justify-center"></div>
            </div>
        </div>
        
        <p class="text-center text-slate-400 text-xs mt-8">© 2026 Quản lý khách hàng - KMA IT Developer</p>
    </div>
    <script src="/javascript/formKhachHang.js"></script>
</div>